# ============================================================================
# cal.nvt.one — production env (TEST). Copié vers `.env` sur le serveur.
# Les secrets vides ("") sont générés automatiquement par deploy.sh au 1er run
# et conservés ensuite. NE PAS committer ce fichier rempli.
# ============================================================================

NODE_ENV=production
CALCOM_TELEMETRY_DISABLED=1

# --- URLs publiques (NEXT_PUBLIC_* sont figées au build) ---
NEXT_PUBLIC_WEBAPP_URL=https://cal.nvt.one
NEXTAUTH_URL=https://cal.nvt.one
WEB_APP_URL=https://cal.nvt.one
# L'API v2 doit être joignable publiquement (le Booker l'appelle pour les créneaux).
# Le reverse-proxy doit router https://cal.nvt.one/api/v2 -> conteneur calcom-api.
NEXT_PUBLIC_API_V2_URL=https://cal.nvt.one/api/v2

# --- Secrets (générés au 1er run si vides) ---
NEXTAUTH_SECRET=
CALENDSO_ENCRYPTION_KEY=
JWT_SECRET=

# --- Base de données (conteneur postgres du compose) ---
POSTGRES_USER=calcom
POSTGRES_PASSWORD=
POSTGRES_DB=calendso
DATABASE_HOST=database:5432
# DATABASE_URL est aussi consommée comme build-arg + DATABASE_DIRECT_URL ; gardée cohérente par deploy.sh.
DATABASE_URL=postgresql://calcom:PASSWORD_PLACEHOLDER@database:5432/calendso

# --- Redis (conteneur) ---
REDIS_URL=redis://redis:6379
REDIS_PORT=6379

# --- Façade Caddy : port hôte recevant le trafic d'Evolix (HTTPS pass-through) ---
HOST_PORT=10226

# --- API v2 ---
API_PORT=3002
API_URL=https://cal.nvt.one
API_KEY_PREFIX=cal_
REWRITE_API_V2_PREFIX=1
LOG_LEVEL=info
LOGGER_BRIDGE_LOG_LEVEL=1
IS_E2E=false
ENABLE_ASYNC_TASKER=false

# --- Fonctionnalités restaurées (clean-room) ---
TEAMS_ENABLED=true

# --- SSO Keycloak (désactivé tant que non rempli) ---
SSO_KEYCLOAK_ENABLED=false
KEYCLOAK_ISSUER=https://YOUR-KEYCLOAK-HOST/realms/YOUR-REALM
KEYCLOAK_CLIENT_ID=cal-nt
KEYCLOAK_CLIENT_SECRET=REPLACE_ME
SSO_KEYCLOAK_DISABLE_PASSWORD_LOGIN=false

# --- Email (à configurer pour invitations/notifications) ---
# EMAIL_FROM=cal@nvt.one
# EMAIL_SERVER_HOST=
# EMAIL_SERVER_PORT=587
# EMAIL_SERVER_USER=
# EMAIL_SERVER_PASSWORD=

# --- Stripe (valeurs factices : requises pour démarrer l'API v2, pas de billing) ---
STRIPE_API_KEY=sk_test_dummy_1234567890
STRIPE_WEBHOOK_SECRET=whsec_dummy_1234567890
NEXT_PUBLIC_LICENSE_CONSENT=
CALCOM_LICENSE_KEY=
